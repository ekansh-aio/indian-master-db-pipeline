{
  "settings": {
    "number_of_shards": 4,
    "number_of_replicas": 0,
    "refresh_interval": "30s",
    "index": {
      "max_result_window": 100000
    }
  },
  "mappings": {
    "properties": {
      "doc_id":               { "type": "keyword" },
      "act_name":             { "type": "text", "analyzer": "standard", "fields": { "keyword": { "type": "keyword" } } },
      "act_number":           { "type": "keyword" },
      "year":                 { "type": "integer" },
      "state":                { "type": "keyword" },
      "state_display":        { "type": "keyword" },
      "jurisdiction":         { "type": "keyword" },
      "source":               { "type": "keyword" },
      "source_url":           { "type": "keyword", "index": false },
      "handle_id":            { "type": "keyword" },
      "pdf_url":              { "type": "keyword", "index": false },
      "pdf_exists":           { "type": "boolean" },
      "pdf_file_size_bytes":  { "type": "long" },
      "language_original":    { "type": "keyword" },
      "language_confidence":  { "type": "float" },
      "ocr_applied":          { "type": "boolean" },
      "ocr_page_count":       { "type": "integer" },
      "total_page_count":     { "type": "integer" },
      "_is_translated":       { "type": "boolean" },
      "total_chars":          { "type": "long" },
      "total_chunks":         { "type": "integer" },
      "scrape_timestamp":     { "type": "keyword" },
      "processed_at":         { "type": "keyword" },

      "chunks": {
        "type": "nested",
        "properties": {
          "chunk_id":   { "type": "keyword" },
          "text":       { "type": "text", "analyzer": "standard" },
          "embedding": {
            "type": "dense_vector",
            "dims": 384,
            "index": true,
            "similarity": "cosine",
            "index_options": { "type": "int8_hnsw" }
          }
        }
      }
    }
  }
}
